# ─────────────────────────────────────────────────────────────
# Supabase connection — copy to `.env.local` and fill in.
#   cp .env.example .env.local
#
# LOCAL DEV: run `pnpm exec supabase start`, then `pnpm exec supabase status`
#            to print the URL + anon/service_role keys for the local stack.
# PRODUCTION: values live in your Supabase project → Settings → API / Database.
# ─────────────────────────────────────────────────────────────

# ── Client (safe to expose to the browser) ──────────────────
# Local stack default URL is http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
# Anon / publishable key. Local: from `supabase status`. Prod: Settings → API.
# (Newer projects call this the "publishable" key, sb_publishable_...)
NEXT_PUBLIC_SUPABASE_ANON_KEY="<anon-or-publishable-key>"

# ── Server only (NEVER expose to the browser / never NEXT_PUBLIC_) ──
# Bypasses RLS — use only in server code (route handlers, server actions).
# (Newer projects call this the "secret" key, sb_secret_...)
SUPABASE_SERVICE_ROLE_KEY="<service-role-or-secret-key>"

# ── Database (direct SQL: migrations, server-side clients, psql) ──
# Pooled connection (PgBouncer, port 6543) — use for the app's runtime queries.
# Local default: postgresql://postgres:postgres@127.0.0.1:54322/postgres
DATABASE_URL="postgresql://postgres:<password>@<host>:6543/postgres?pgbouncer=true&sslmode=require"
# Direct connection (port 5432) — use for running migrations (no PgBouncer).
DIRECT_URL="postgresql://postgres:<password>@<host>:5432/postgres?sslmode=require"

# ── Storage ─────────────────────────────────────────────────
# Storage uses the same URL + keys above. Set the bucket the app reads/writes.
# Create it once: Supabase Studio → Storage → New bucket (private).
SUPABASE_STORAGE_BUCKET="resident-photos"
